{
  "name": "QAI",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_icon": "main.png"
  },
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.alislam.org/*",
    "https://alislam.org/*"
  ],
  "permissions": [
    "sidePanel",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "sidebar_action": {
    "default_panel": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quranai@example.com",
      "strict_min_version": "109.0"
    }
  }
}
